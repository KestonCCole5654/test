{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.js"
    }
  ],
  "includeFiles": [
    "config/**",
    "node_modules/**",
    ".env",
    "index.js",
    "package.json",
    "package-lock.json"
  ],
  "excludeFiles": ["client/**"]
}